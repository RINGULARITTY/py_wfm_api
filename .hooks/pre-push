#!/usr/bin/env bash
# Hook git pre-push — bloque le push si la testsuite échoue.
# Installé par : bash scripts/install_hooks.sh

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║  WFM — Vérification pré-push             ║"
echo "╚══════════════════════════════════════════╝"

# Vérifie que pytest est disponible
if ! command -v pytest &>/dev/null; then
    echo "⚠  pytest introuvable. Installez-le : pip install pytest"
    echo "   Push annulé."
    exit 1
fi

echo ""
echo "▶ Tests unitaires (sans réseau)..."
if ! pytest -m "not integration" --tb=short -q; then
    echo ""
    echo "✗  Des tests ont échoué. Push annulé."
    echo "   Corrigez les erreurs puis relancez : git push"
    exit 1
fi

echo ""
echo "▶ Tests d'intégration (lecture seule)..."
if ! pytest -m "integration and not auth" --tb=short -q; then
    echo ""
    echo "⚠  Des tests d'intégration ont échoué."
    echo "   Vérifiez votre connexion ou l'état de l'API WFM."
    echo "   Push annulé."
    exit 1
fi

echo ""
echo "✓  Tous les tests sont passés. Push en cours..."
echo ""
exit 0
